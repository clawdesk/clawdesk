{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/tooling/cli/schema.json",
  "productName": "ClawDesk",
  "version": "0.1.0",
  "identifier": "ai.clawdesk.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bash -lc 'ROOT=\"$(git rev-parse --show-toplevel)\" && bash \"$ROOT/scripts/download-llama-server.sh\" && pnpm --dir \"$ROOT/crates/ui\" dev'",
    "beforeBuildCommand": "bash -lc 'ROOT=\"$(git rev-parse --show-toplevel)\" && bash \"$ROOT/scripts/download-llama-server.sh\" && pnpm --dir \"$ROOT/crates/ui\" build'"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ClawDesk",
        "width": 1280,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 720,
        "backgroundColor": "#f7f8fc",
        "decorations": true,
        "theme": "Light",
        "titleBarStyle": "Overlay",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main",
          "description": "Capabilities for ClawDesk main window",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default",
            "core:window:allow-start-dragging",
            "autostart:default",
            "shell:default",
            {
              "identifier": "shell:allow-spawn",
              "allow": [
                {
                  "name": "binaries/llama-server",
                  "sidecar": true,
                  "args": true
                }
              ]
            },
            "shell:allow-kill",
            "shell:allow-stdin-write"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/llama-server"
    ],
    "resources": {
      "binaries/lib*": "./"
    }
  }
}
